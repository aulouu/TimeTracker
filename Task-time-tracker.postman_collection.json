{
  "info": {
    "_postman_id": "bba1239a-0da9-4135-8b69-3b26631f0b59",
    "name": "Task time tracker API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Register",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"testuser\",\n  \"password\": \"password1\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/register",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "register"]
        }
      }
    },
    {
      "name": "Login",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"testuser\",\n  \"password\": \"password1\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/login",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "login"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const res = pm.response.json();",
              "pm.collectionVariables.set('token', res.token);"
            ]
          }
        }
      ]
    },
    {
      "name": "Create Employee",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"firstName\": \"Ivan\",\n  \"lastName\": \"Petrov\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/employees",
          "host": ["{{baseUrl}}"],
          "path": ["api", "employees"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const res = pm.response.json();",
              "pm.collectionVariables.set('employeeId', res.id);"
            ]
          }
        }
      ]
    },
    {
      "name": "Get Employee By Id",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/employees/{{employeeId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "employees", "{{employeeId}}"]
        }
      }
    },
    {
      "name": "Create Task",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Task title\",\n  \"description\": \"Task description\",\n  \"status\": \"NEW\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/tasks",
          "host": ["{{baseUrl}}"],
          "path": ["api", "tasks"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const res = pm.response.json();",
              "pm.collectionVariables.set('taskId', res.id);"
            ]
          }
        }
      ]
    },
    {
      "name": "Get Task By Id",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/tasks/{{taskId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "tasks", "{{taskId}}"]
        }
      }
    },
    {
      "name": "Update Task Status",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"status\": \"IN_PROGRESS\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/tasks/{{taskId}}/status",
          "host": ["{{baseUrl}}"],
          "path": ["api", "tasks", "{{taskId}}", "status"]
        }
      }
    },
    {
      "name": "Create Time Record",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"employeeId\": {{employeeId}},\n  \"taskId\": {{taskId}},\n  \"startTime\": \"2026-04-13T09:00:00\",\n  \"endTime\": \"2026-04-13T11:00:00\",\n  \"workDescription\": \"Implemented API\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/time-records",
          "host": ["{{baseUrl}}"],
          "path": ["api", "time-records"]
        }
      }
    },
    {
      "name": "Get Employee Time Report (period)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"employeeId\": {{employeeId}},\n  \"startTime\": \"2026-04-13T00:00:00\",\n  \"endTime\": \"2026-04-14T00:00:00\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/time-records/period",
          "host": ["{{baseUrl}}"],
          "path": ["api", "time-records", "period"]
        }
      }
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "token", "value": "" },
    { "key": "employeeId", "value": "" },
    { "key": "taskId", "value": "" }
  ]
}
